<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>

<GridPane prefHeight="400" prefWidth="800" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.Nansy_desktop.controller.MainController">
    <columnConstraints>
      <ColumnConstraints percentWidth="100" prefWidth="150" />
    </columnConstraints>

    <rowConstraints>
      <RowConstraints percentHeight="93" prefHeight="100" />
      <RowConstraints percentHeight="7" prefHeight="100" />
    </rowConstraints>
    
    <children>
      <HBox prefHeight="100.0" prefWidth="200.0" GridPane.rowIndex="1" spacing="10">
         <children>
            <Button maxHeight="Infinity" maxWidth="Infinity" text="Редактор комманд" onAction="#openCommandEditorWindow"/>
            <Button maxHeight="Infinity" maxWidth="Infinity" text="Button" />
         </children>
      </HBox>
    </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</GridPane>
